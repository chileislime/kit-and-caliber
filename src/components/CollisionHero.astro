---
interface Props {
  matchNo: number;
  eyebrow: string;
  watch: string;
  car: string;
  verdict: string;
  hook: string;
  href: string;
}

const { matchNo, eyebrow, watch, car, verdict, hook, href } = Astro.props;
const no = String(matchNo).padStart(2, '0');
---

<section class="hero">
  <div class="wrap">
    <div class="eyebrow">
      <span class="no">CALIBER MATCH №{no}</span>
      <span class="mono">{eyebrow}</span>
    </div>

    <div class="collision anim" aria-label={`${watch} paired with ${car}`}>
      <span class="line">{watch}</span>
      <span class="pivot" aria-hidden="true">×</span>
      <span class="line">{car}</span>
    </div>

    <p class="verdict-lead">{verdict}</p>

    <div class="hookrow">
      <a class="btn" href={href}>See the tape →</a>
      <span class="hook">{hook}</span>
    </div>
  </div>
</section>
