---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CollisionHero from '../components/CollisionHero.astro';

const pairings = (await getCollection('pairings', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.matchNo - a.data.matchNo
);

const featured = pairings[0];
---

<BaseLayout>
  <CollisionHero
    matchNo={featured.data.matchNo}
    eyebrow={featured.data.eyebrow}
    watch={featured.data.watch}
    car={featured.data.car}
    verdict={featured.data.verdict}
    hook={featured.data.hook}
    href={`/pairings/${featured.id}`}
  />

  <section class="index" id="filed">
    <div class="wrap">
      <div class="sechead">Filed &middot; {String(pairings.length).padStart(2, '0')} matches</div>
      {
        pairings.map((entry) => (
          <a class="irow" href={`/pairings/${entry.id}`}>
            <span class="n">№{String(entry.data.matchNo).padStart(2, '0')}</span>
            <span class="p">
              {entry.data.watch} <span class="x">×</span> {entry.data.car}
            </span>
            {entry.data.teaser && <span class="rv">{entry.data.teaser}</span>}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
