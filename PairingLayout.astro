---
import BaseLayout from './BaseLayout.astro';
import CollisionHero from '../components/CollisionHero.astro';
import TaleOfTheTape from '../components/TaleOfTheTape.astro';

interface TapeRow {
  spec: string;
  left: string;
  right: string;
}

interface Props {
  frontmatter: {
    matchNo: number;
    watch: string;
    watchDetail?: string;
    car: string;
    eyebrow: string;
    verdict: string;
    hook: string;
    filedUnder?: string;
    tape: TapeRow[];
  };
}

const { frontmatter } = Astro.props;
const { matchNo, watch, watchDetail, car, eyebrow, verdict, hook, filedUnder, tape } =
  frontmatter;
---

<BaseLayout title={`${watch} × ${car} · Kit & Caliber`} description={verdict}>
  <CollisionHero
    matchNo={matchNo}
    eyebrow={eyebrow}
    watch={watch}
    car={car}
    verdict={verdict}
    hook={hook}
    href="#tape"
  />

  <TaleOfTheTape left={watch} right={car} rows={tape} />

  <article class="article">
    <div class="wrap">
      {
        watchDetail && (
          <p class="subpair">
            {watch}, {watchDetail} <span class="x">×</span> {car}
          </p>
        )
      }
      <div class="prose">
        <slot />
      </div>
      {filedUnder && <p class="filed-note">Filed under: {filedUnder}</p>}
    </div>
  </article>
</BaseLayout>
