---
interface Props {
  label?: string;
}

// The recurring "lived experience with the object" beat. Use it when the
// pairing comes from ownership rather than admiration; skip it otherwise.
const { label = 'worn, not researched' } = Astro.props;
---

<aside class="fieldnotes">
  <div class="fn-label">Field Notes // {label}</div>
  <div class="fn-body">
    <slot />
  </div>
</aside>
